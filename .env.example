# Supabase (from https://app.supabase.com/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only, NEVER expose to client. Service role bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Drizzle (direct Postgres URL via Supabase pooler, transaction mode)
# Source: Supabase Dashboard > Project Settings > Database > Connection string > URI (pooler, mode=transaction)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Kakao OAuth feature flag. Set to 'true' only after the Kakao Business app is
# approved AND account_email scope is granted. Until then, the Kakao login
# button renders disabled with a "준비 중" tooltip (D-01.1).
# See docs/auth/KAKAO_BUSINESS_APP.md
NEXT_PUBLIC_KAKAO_ENABLED=false

# Sentry (Plan 07 — leave blank in Plan 01)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Revalidate webhook shared secret (Phase 4a will use; generate now)
REVALIDATE_SECRET=

# Heartbeat endpoint key (Plan 07)
HEARTBEAT_SECRET=

# Resend (Plan 06 — DSAR email verification)
# Sign up at https://resend.com (free tier 3,000/mo, 100/day) and verify a sending domain.
# See docs/compliance/CPO_FORWARDING_ALIAS.md for the CPO alias setup.
RESEND_API_KEY=
DSAR_FROM_EMAIL=noreply@YOUR_DOMAIN
DSAR_ADMIN_NOTIFY_EMAIL=privacy@YOUR_DOMAIN

# Rate limiting (Plan 06 — DSAR submission cap per IP per hour)
DSAR_RATE_LIMIT_PER_HOUR=5

